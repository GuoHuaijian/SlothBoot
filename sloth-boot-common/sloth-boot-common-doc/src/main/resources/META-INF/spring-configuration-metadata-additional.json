      "type": "java.lang.String",
      "description": "Contact name."
    },
    {
      "name": "sloth.doc.contact-email",
      "type": "java.lang.String",
      "description": "Contact email."
    },
    {
      "name": "sloth.doc.contact-url",
      "type": "java.lang.String",
